{
  "name": "agentic_report_writing_supporter",
  "version": "1.0.0",
  "description": "Agentic Report Writing Supporter - CLI Orchestration",
  "main": "dist/index.js",
  "bin": {
    "agentic-writer": "./dist/index.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc",
    "build:bin": "pkg .",
    "start": "ts-node src/index.ts orchestration-config.yaml",
